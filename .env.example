# AOS Admin credentials
AOS_ADMIN_USERNAME=
AOS_ADMIN_PASSWORD=
# Optional safer alternative: SHA-256 hash of the password. If set, this wins over AOS_ADMIN_PASSWORD.
AOS_ADMIN_PASSWORD_HASH=
AOS_ADMIN_SESSION_SECRET=

# GitHub repository used by the admin portal to save content updates
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=
# Leave blank when aosagra-modern is the repo root. Use "aosagra-modern" if the repo contains this folder.
GITHUB_PROJECT_PATH=
