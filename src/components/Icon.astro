---
type IconName =
  | "arrow-right"
  | "book"
  | "calendar"
  | "check"
  | "chevron-down"
  | "clock"
  | "close"
  | "download"
  | "external"
  | "file"
  | "heart"
  | "image"
  | "mail"
  | "map-pin"
  | "menu"
  | "phone"
  | "search"
  | "shield"
  | "users";

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  label?: string;
}

const { name, size = 20, strokeWidth = 1.8, label } = Astro.props;

