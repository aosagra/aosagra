---
import TajMotif from "./TajMotif.astro";

interface Props {
  title: string;
  summary: string;
  group?: string;
}

const { title, summary, group } = Astro.props;
---

<section class="page-intro">
  <TajMotif tone="white" class="page-intro__taj" />
  <div class="shell page-intro__inner">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      {group && <span>{group}</span>}
    </nav>
    <h1>{title}</h1>
    <p>{summary}</p>
  </div>
</section>
