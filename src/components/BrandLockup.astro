---
interface Props {
  compact?: boolean;
  inverse?: boolean;
}

const { compact = false, inverse = false } = Astro.props;
---

<a class:list={["brand-lockup", { compact, inverse }]} href="/" aria-label="Agra Orthopaedic Society home">
  <span class="affiliation-marks" aria-label="Affiliated orthopaedic association marks">
    <img src="/assets/brand/ioa-seal.png" width="124" height="168" alt="Indian Orthopaedic Association" loading="eager" />
    <img src="/assets/brand/ioa-red-seal.png" width="102" height="104" alt="Indian Orthopaedic Association seal" loading="eager" />
  </span>
  <img class="aos-mark" src="/assets/brand/aos-mark.png" width="92" height="61" alt="" aria-hidden="true" loading="eager" />
  <span class="brand-copy">
    <strong>Agra Orthopaedic Society</strong>
    <small>Education · Ethics · Excellence</small>
  </span>
</a>
