<aside class="font-preview-toolbar" data-font-toolbar hidden aria-label="Typography preview controls">
  <span class="font-preview-toolbar__label">Type preview</span>
  <div class="font-preview-toolbar__options" role="group" aria-label="Font pairing">
    <button type="button" data-font-option="source">Current</button>
    <button type="button" data-font-option="civic">Civic</button>
    <button type="button" data-font-option="agra">Agra</button>
    <button type="button" data-font-option="contemporary">Contemporary</button>
  </div>
  <a href="/type-lab/" data-font-lab-link>Compare</a>
  <button class="font-preview-toolbar__close" type="button" data-font-toolbar-close aria-label="Close typography preview">×</button>
</aside>

<script is:inline>
  (() => {
    const toolbar = document.querySelector("[data-font-toolbar]");
    if (!(toolbar instanceof HTMLElement)) return;

    const params = new URLSearchParams(window.location.search);
    if (params.get("fontlab") !== "1") return;

    const allowed = new Set(["source", "civic", "agra", "contemporary"]);
    const options = [...toolbar.querySelectorAll("[data-font-option]")];
    const compareLink = toolbar.querySelector("[data-font-lab-link]");

    const applyFont = (font) => {
      const next = allowed.has(font) ? font : "source";
      document.documentElement.dataset.font = next;
      params.set("font", next);
      params.set("fontlab", "1");
      history.replaceState(null, "", `${window.location.pathname}?${params.toString()}${window.location.hash}`);
      options.forEach((option) => option.setAttribute("aria-pressed", String(option.dataset.fontOption === next)));
      if (compareLink instanceof HTMLAnchorElement) compareLink.href = `/type-lab/?font=${next}&fontlab=1`;
    };

    toolbar.hidden = false;
    applyFont(document.documentElement.dataset.font ?? "source");

    options.forEach((option) => {
      option.addEventListener("click", () => applyFont(option.dataset.fontOption ?? "source"));
    });

    toolbar.querySelector("[data-font-toolbar-close]")?.addEventListener("click", () => {
      document.documentElement.dataset.font = "source";
      params.delete("font");
      params.delete("fontlab");
      const query = params.toString();
      history.replaceState(null, "", `${window.location.pathname}${query ? `?${query}` : ""}${window.location.hash}`);
      toolbar.hidden = true;
    });
  })();
</script>
