---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import TajMotif from "../components/TajMotif.astro";
---

<BaseLayout title="Page not found" description="The requested AOS Agra page could not be found.">
  <section class="not-found">
    <TajMotif tone="white" class="not-found__taj" />
    <div class="shell not-found__inner">
      <p>404</p>
      <h1>This page has moved beyond the archive.</h1>
      <p>Return home, browse current events, or contact the society if you were looking for an older AOS record.</p>
      <div>
        <a class="button button--gold" href="/">Return home</a>
        <a class="text-link text-link--light" href="/contact/">Contact AOS <Icon name="arrow-right" size={18} /></a>
      </div>
    </div>
  </section>
</BaseLayout>
