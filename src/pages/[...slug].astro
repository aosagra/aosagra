---
import BaseLayout from "../layouts/BaseLayout.astro";
import EventList from "../components/EventList.astro";
import Gallery from "../components/Gallery.astro";
import Icon from "../components/Icon.astro";
import PageIntro from "../components/PageIntro.astro";
import {
  publicPages,
  archivedPresidentMessage,
  currentExecutive2026,
  executiveBody2025,
  leaders,
  mainNavigation,
  notices,
  organization,
  pastPresidents,
  pastEvents,
  secretaryMessage,
  videoRecordings,
  type ContentPage
} from "../data/site";

export function getStaticPaths() {
  return publicPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

interface Props {
  page: ContentPage;
}

const { page } = Astro.props;
const canonicalPath = `/${page.canonicalSlug ?? page.slug}/`;
const groupLabelByLegacyGroup: Record<string, string> = {
  "About AOS": "Society",
  Academics: "Learning",
  "Events & CME": "Events",
  Membership: "Membership",
  "Public Awareness": "Public",
  "AOS Connect": "Learning"
};
const directGroupNavigation = mainNavigation.find(
  (group) =>
    group.href === canonicalPath ||
    group.items.some((item) => item.href === canonicalPath)
);
const groupNavigation = directGroupNavigation ?? mainNavigation.find(
  (group) => group.label === groupLabelByLegacyGroup[page.group]
);
const introGroup = groupNavigation?.label ?? groupLabelByLegacyGroup[page.group] ?? page.group;
const linkAttrs = (href: string) => href.startsWith("http") ? { target: "_blank", rel: "noreferrer" } : {};
const showComingSoon = false;
const memberAreaActions: {
  icon: "users" | "book" | "mail";
  title: string;
  copy: string;
  href: string;
  cta: string;
}[] = [
  {
    icon: "users",
    title: "Update AOS Digital Directory",
    copy: "Use the current society directory form to submit or correct your member record for 2026-2027.",
    href: "https://forms.gle/9G18h7ZcSaoSEbkV8",
    cta: "Open directory form"
  },
  {
    icon: "book",
    title: "Share member activities",
    copy: "Submit academic, community, publication, award, and professional activity updates for review before website publication.",
    href: "https://forms.gle/sX8MFRRGxyCxaezQA",
    cta: "Submit activity update"
  },
  {
    icon: "mail",
    title: "Send corrections to AOS",
    copy: "For corrections that should stay outside public forms, contact the society office directly.",
    href: `mailto:${organization.email}`,
    cta: "Email AOS"
  }
];
const memberAreaSteps = [
  "Secure login for verified AOS members.",
  "Member profile correction and consent review.",
  "Member-only directory and approved society documents.",
  "CME certificates, circulars, and academic resources as records are prepared."
];
const currentExecutiveGroupOrder = [
  "Office Bearers",
  "Executive Members",
  "Patrons / Past Presidents",
  "Special Invitees / Advisors",
  "Designation to be updated"
];
const currentExecutiveGroups = currentExecutiveGroupOrder
  .map((group) => ({
    group,
    members: currentExecutive2026.filter((member) => member.group === group)
  }))
  .filter((entry) => entry.members.length > 0);
const publicAwarenessTopics = [
  {
    title: "Knee Pain & Arthritis",
    label: "Osteoarthritis series",
    copy: "Movement, X-rays, warning signs, weight, and treatment decisions in plain patient language.",
    href: "/knee-pain-arthritis/"
  },
  {
    title: "Shoulder Problems",
    label: "Myth-buster series",
    copy: "Frozen shoulder, cervical pain, rotator cuff tears, MRI decisions, and safe exercise.",
    href: "/shoulder-problems/"
  },
  {
    title: "Night Leg Cramps",
    label: "Practical self-care",
    copy: "रात में पिंडली या पैर की अकड़न, राहत, बचाव और कब doctor review जरूरी है.",
    href: "/night-leg-cramps/"
  },
  {
    title: "Trusted OrthoInfo Links",
    label: "Further reading",
    copy: "Curated AAOS OrthoInfo links grouped by common public-awareness topics.",
    href: "/trusted-orthoinfo-links/"
  },
  {
    title: "Hindi Awareness",
    label: "Facebook archive",
    copy: "A place to organise Hindi patient-awareness topics before and after Facebook posting.",
    href: "/hindi-public-awareness/"
  }
];
---

<BaseLayout title={page.title} description={page.summary} canonicalPath={canonicalPath} image={page.image}>
  <PageIntro title={page.title} summary={page.summary} group={introGroup} />

  <div class="shell interior">
    <article class="interior__content">
      {
        page.image && (
          <figure class="content-image">
            <img src={page.image} width="1280" height="853" alt="" />
          </figure>
        )
      }

      {
        showComingSoon && (
          <section class="coming-soon">
            <span class="coming-soon__icon"><Icon name="clock" size={24} /></span>
            <div>
              <h2>Being prepared with care</h2>
              <p>
                This destination is part of the new AOS structure, but the source material is still being verified and organised. It will be published here when ready.
              </p>
              <a class="text-link" href="/contact/">Share material or ask AOS <Icon name="arrow-right" size={17} /></a>
            </div>
          </section>
        )
      }

      {
        page.kind === "leadership" && (
          <section aria-labelledby="current-office-bearers">
            <div class="content-heading">
              <h2 id="current-office-bearers">Current office bearers</h2>
              <p>Leadership information reflects the latest society update available in June 2026.</p>
            </div>
            <div class="leadership__grid leadership__grid--interior">
              {leaders.map((leader) => (
                <article class="leader">
                  <img src={leader.image} width="375" height="496" alt={leader.name} />
                  <div>
                    <p>{leader.role}</p>
                    <h3>{leader.name}</h3>
                  </div>
                </article>
              ))}
            </div>
            <div class="leadership-related">
              <div>
                <h3>Photographs and full roster</h3>
                <p>
                  The President, Hon. General Secretary, and Treasurer photographs are available now and shown above. The full Executive Committee 2026 roster is published separately; individual photographs can be added there as they are received.
                </p>
              </div>
              <a class="text-link" href="/executive-committee/">View present executive committee <Icon name="arrow-right" size={17} /></a>
            </div>
          </section>
        )
      }

      {
        page.kind === "current-executive" && (
          <section class="current-executive" aria-labelledby="current-executive-heading">
            <div class="content-heading">
              <h2 id="current-executive-heading">Present executive roster</h2>
              <p>
                Names and designations are listed from the AOS Executive 2026 spreadsheet. Individual photographs can be added as they are received.
              </p>
            </div>
            <div class="archive-note">
              <Icon name="file" size={20} />
              <p>Public roster · Names and designations only</p>
            </div>
            <div class="executive-groups">
              {currentExecutiveGroups.map((entry) => (
                <section class="executive-group" aria-labelledby={`executive-${entry.group.toLowerCase().replaceAll(" ", "-").replaceAll("/", "")}`}>
                  <div class="executive-group__head">
                    <h3 id={`executive-${entry.group.toLowerCase().replaceAll(" ", "-").replaceAll("/", "")}`}>{entry.group}</h3>
                    <span>{entry.members.length} {entry.members.length === 1 ? "member" : "members"}</span>
                  </div>
                  <div class="executive-roster">
                    {entry.members.map((member) => (
                      <article class="executive-member">
                        <strong>{member.name}</strong>
                        <span>{member.role}</span>
                      </article>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </section>
        )
      }

      {
        page.kind === "past-leadership" && (
          <section aria-labelledby="past-presidents-heading">
            <div class="content-heading">
              <h2 id="past-presidents-heading">Presidents recorded in the legacy archive</h2>
              <p>
                The entries below are transcribed from the previous AOS website. The source contains overlapping early terms and two entries for Dr Anuj Kumar; those details are preserved visibly rather than silently changed.
              </p>
            </div>
            <div class="archive-note">
              <Icon name="file" size={20} />
              <p>Historical register · Source dates require final society verification</p>
            </div>
            <div class="archive-table-wrap">
              <table class="archive-table">
                <caption>Past Presidents of the Agra Orthopaedic Society</caption>
                <thead>
                  <tr>
                    <th scope="col">President</th>
                    <th scope="col">Term recorded</th>
                  </tr>
                </thead>
                <tbody>
                  {pastPresidents.map((president) => (
                    <tr>
                      <th scope="row">{president.name}</th>
                      <td>{president.term}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="archive-pending">
              <div>
                <h3>Past Secretaries</h3>
                <p>The corresponding secretaries register was empty on the legacy website and remains under verification.</p>
              </div>
              <a class="text-link" href="/contact/">Help complete the record <Icon name="arrow-right" size={17} /></a>
            </div>
          </section>
        )
      }

      {
        page.kind === "archive-roster" && (
          <section aria-labelledby="archived-roster-heading">
            <div class="content-heading">
              <h2 id="archived-roster-heading">Archived executive roster</h2>
              <p>
                This is the 2025–2026 body shown on the previous website. It is retained for institutional continuity and is not the current leadership list.
              </p>
            </div>
            <div class="archive-note">
              <Icon name="clock" size={20} />
              <p>Previous term · For the latest office bearers, see <a href="/office-bearers/">current leadership</a>.</p>
            </div>
            <div class="roster-list">
              {executiveBody2025.map((member) => (
                <div>
                  <strong>{member.name}</strong>
                  <span>{member.role}</span>
                </div>
              ))}
            </div>
          </section>
        )
      }

      {
        page.kind === "archived-message" && (
          <section class="archived-message" aria-labelledby="archived-message-heading">
            <div class="archived-message__portrait">
              <img
                src={archivedPresidentMessage.image}
                width="375"
                height="496"
                alt={archivedPresidentMessage.author}
              />
              <p><strong>{archivedPresidentMessage.author}</strong><span>{archivedPresidentMessage.role}</span></p>
            </div>
            <div class="archived-message__copy">
              <div class="archive-note">
                <Icon name="clock" size={20} />
                <p>Archived message · Preserved from the previous AOS website</p>
              </div>
              <h2 id="archived-message-heading">From the President’s desk</h2>
              {archivedPresidentMessage.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              <p class="archived-message__signoff">Warm regards,<br /><strong>{archivedPresidentMessage.author}</strong></p>
            </div>
          </section>
        )
      }

      {
        page.kind === "secretary-message" && (
          <section class="secretary-message" aria-labelledby="secretary-message-heading">
            <figure class="secretary-message__portrait">
              <img src={secretaryMessage.image} width="375" height="496" alt={secretaryMessage.author} />
              <figcaption>
                <strong>{secretaryMessage.author}</strong>
                <span>{secretaryMessage.role}</span>
              </figcaption>
            </figure>
            <div class="secretary-message__copy">
              <div class="archive-note">
                <Icon name="file" size={20} />
                <p>Current message · Built from the AOS academic, governance, directory, and public-awareness planning material</p>
              </div>
              <h2 id="secretary-message-heading">{secretaryMessage.headline}</h2>
              <div class="secretary-message__letter">
                {secretaryMessage.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                <p class="secretary-message__signoff">
                  Warm regards,<br />
                  <strong>{secretaryMessage.author}</strong><br />
                  <span>{secretaryMessage.role}</span>
                </p>
              </div>

              <div class="secretary-message__priorities" aria-label="Secretary message priorities">
                {secretaryMessage.priorities.map((priority) => (
                  <article>
                    <h3>{priority.title}</h3>
                    <p>{priority.text}</p>
                  </article>
                ))}
              </div>

              <div class="secretary-message__links">
                {secretaryMessage.links.map((link) => (
                  <a class="text-link" href={link.href}>{link.label} <Icon name="arrow-right" size={17} /></a>
                ))}
              </div>
            </div>
          </section>
        )
      }

      {
        page.kind === "events" && (
          <section aria-labelledby="current-events">
            <div class="content-heading">
              <h2 id="current-events">July 2026 programme</h2>
              <p>Current dates published by the Agra Orthopaedic Society.</p>
            </div>
            <EventList />
          </section>
        )
      }

      {
        page.kind === "past-events" && (
          <section aria-labelledby="completed-events">
            <div class="content-heading">
              <h2 id="completed-events">Completed events</h2>
              <p>This archive will grow as older society records are verified.</p>
            </div>
            <div class="event-list">
              {pastEvents.map((event) => (
                <article class="event-row" id={event.id}>
                  <time datetime={event.datetime} class="event-date event-date--past">
                    <strong>{event.date}</strong>
                    <span>{event.month} {event.year}</span>
                  </time>
                  <div class="event-row__content">
                    <h3>{event.title}</h3>
                    <p>{event.description}</p>
                    <span class="event-row__meta"><Icon name="check" size={16} /> {event.meta}</span>
                  </div>
                  <a class="text-link" href={event.href}>
                    Event record <Icon name="arrow-right" size={17} />
                  </a>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        page.kind === "gallery" && (
          <section aria-labelledby="gallery-heading">
            <div class="content-heading">
              <h2 id="gallery-heading">Society photographs</h2>
              <p>Select a photograph to view it at a larger size.</p>
            </div>
            <Gallery />
          </section>
        )
      }

      {
        page.kind === "contact" && (
          <div class="contact-layout">
            <section class="contact-details" aria-labelledby="contact-details">
              <h2 id="contact-details">Society office</h2>
              <a href={`mailto:${organization.email}`}><Icon name="mail" size={20} /><span><small>Email</small>{organization.email}</span></a>
              <a href={`tel:${organization.phoneHref}`}><Icon name="phone" size={20} /><span><small>Phone</small>{organization.phone}</span></a>
              <p><Icon name="map-pin" size={20} /><span><small>Address</small>{organization.address}</span></p>
            </section>
            <section class="contact-direct" aria-labelledby="contact-direct">
              <div class="content-heading">
                <h2 id="contact-direct">Start with a direct conversation</h2>
                <p>Email or call the society office. Membership and event enquiries are routed from there until secure forms are connected.</p>
              </div>
              <div class="contact-direct__actions">
                <a class="button button--primary" href={`mailto:${organization.email}`}>Email AOS</a>
                <a class="button button--light" href={`tel:${organization.phoneHref}`}>Call the office</a>
              </div>
            </section>
          </div>
        )
      }

      {
        page.kind === "member-area" && (
          <section class="member-area" aria-labelledby="member-area-heading">
            <div class="content-heading">
              <h2 id="member-area-heading">Member services, started carefully</h2>
              <p>
                The AOS member area is being opened behind member access. Directory information remains consent-led and is not published as an open public directory for general website visitors.
              </p>
            </div>

            <div class="member-portal" data-member-portal>
              <section class="member-portal__login" data-member-login-panel aria-labelledby="member-login-heading">
                <span class="member-area__icon"><Icon name="shield" size={24} /></span>
                <div>
                  <p class="section-context">Private member access</p>
                  <h3 id="member-login-heading">AOS Digital Directory</h3>
                  <p>
                    Enter your individual AOS member access code to view the internal directory. Contact details are not shown to ordinary site visitors.
                  </p>
                </div>
                <form class="member-portal__form" data-member-login-form>
                  <label>
                    <span>Individual member access code</span>
                    <input name="accessCode" type="password" autocomplete="current-password" required />
                  </label>
                  <button class="button button--primary" type="submit">Open member area</button>
                </form>
                <p class="member-portal__status" data-member-login-status role="status" aria-live="polite"></p>
              </section>

              <section class="member-portal__private" data-member-private hidden aria-labelledby="member-directory-heading">
                <div class="member-portal__bar">
                  <div>
                    <p class="section-context">Members only</p>
                    <h3 id="member-directory-heading">AOS Digital Directory</h3>
                    <span data-member-count>Directory loading…</span>
                  </div>
                  <button class="button button--light" type="button" data-member-logout>Logout</button>
                </div>

                <div class="member-portal__tools">
                  <label>
                    <span>Search directory</span>
                    <input type="search" placeholder="Search by name, city, hospital, interest…" data-member-search />
                  </label>
                  <a class="button button--gold" href="https://forms.gle/9G18h7ZcSaoSEbkV8" target="_blank" rel="noreferrer">Update my profile</a>
                </div>

                <div class="member-portal__message" data-member-directory-message role="status" aria-live="polite"></div>

                <div class="member-directory-wrap" data-member-directory-wrap hidden>
                  <table class="member-directory">
                    <caption>AOS member directory visible only after member access</caption>
                    <thead>
                      <tr>
                        <th scope="col">Member</th>
                        <th scope="col">Practice</th>
                        <th scope="col">Contact</th>
                        <th scope="col">Professional details</th>
                      </tr>
                    </thead>
                    <tbody data-member-directory-body></tbody>
                  </table>
                </div>
              </section>
            </div>

            <div class="member-area__actions">
              {memberAreaActions.map((action) => (
                <a class="member-area__action" href={action.href} target={action.href.startsWith("http") ? "_blank" : undefined} rel={action.href.startsWith("http") ? "noreferrer" : undefined}>
                  <span class="member-area__icon"><Icon name={action.icon} size={23} /></span>
                  <span>
                    <strong>{action.title}</strong>
                    <small>{action.copy}</small>
                    <span class="text-link">{action.cta} <Icon name={action.href.startsWith("http") ? "external" : "arrow-right"} size={16} /></span>
                  </span>
                </a>
              ))}
            </div>

            <div class="member-area__plan">
              <div class="member-area__status">
                <span class="member-area__icon"><Icon name="shield" size={24} /></span>
                <h3>Privacy first</h3>
                <p>
                  Member phone numbers, email addresses, photographs, family details, and directory records will stay off the public website until secure access, member consent, and society verification are complete.
                </p>
              </div>
              <div class="member-area__roadmap">
                <h3>Next portal stages</h3>
                <ol>
                  {memberAreaSteps.map((step) => <li>{step}</li>)}
                </ol>
              </div>
            </div>

            <div class="member-area__note">
              <Icon name="check" size={21} />
              <p>
                Member achievements and activities can be submitted now. Profile corrections should be submitted through the directory form until direct Google Sheet or private database syncing is configured.
              </p>
            </div>
          </section>
        )
      }

      {
        page.kind === "public-directory" && (
          <section class="public-directory" data-public-directory aria-labelledby="public-directory-heading">
            <div class="content-heading">
              <h2 id="public-directory-heading">Orthopaedic surgeons practicing in Agra</h2>
              <p>
                Search the public AOS listing by name, hospital or clinic, qualification, designation, or area of orthopaedic interest.
              </p>
            </div>

            <div class="public-directory__notice">
              <Icon name="shield" size={22} />
              <p>
                This is a public professional listing only. Personal phone numbers, email addresses, photographs, and member-only directory details remain private unless separately approved for public release.
              </p>
            </div>

            <div class="public-directory__tools">
              <label>
                <span>Search public directory</span>
                <input type="search" placeholder="Search by name, clinic, hospital, qualification…" data-public-directory-search />
              </label>
              <span data-public-directory-count>Loading public directory…</span>
            </div>

            <div class="member-portal__message" data-public-directory-message role="status" aria-live="polite"></div>

            <div class="member-directory-wrap" data-public-directory-wrap hidden>
              <table class="member-directory public-directory__table">
                <caption>Public AOS listing of orthopaedic surgeons practicing in Agra</caption>
                <thead>
                  <tr>
                    <th scope="col">Surgeon</th>
                    <th scope="col">Practice</th>
                    <th scope="col">Professional details</th>
                    <th scope="col">Interest</th>
                  </tr>
                </thead>
                <tbody data-public-directory-body></tbody>
              </table>
            </div>

            <div class="public-directory__actions">
              <a class="button button--primary" href="/member-area/">Members: open private directory</a>
              <a class="button button--outline" href="https://forms.gle/9G18h7ZcSaoSEbkV8" target="_blank" rel="noreferrer">Update directory record</a>
              <a class="button button--light" href="/contact/">Send correction to AOS</a>
            </div>
          </section>
        )
      }

      {
        page.kind === "member-area" && (
          <script is:inline>
            (() => {
              const portal = document.querySelector("[data-member-portal]");

              if (!portal) return;

              const loginPanel = portal.querySelector("[data-member-login-panel]");
              const privatePanel = portal.querySelector("[data-member-private]");
              const loginForm = portal.querySelector("[data-member-login-form]");
              const loginStatus = portal.querySelector("[data-member-login-status]");
              const logoutButton = portal.querySelector("[data-member-logout]");
              const countLabel = portal.querySelector("[data-member-count]");
              const message = portal.querySelector("[data-member-directory-message]");
              const wrap = portal.querySelector("[data-member-directory-wrap]");
              const tbody = portal.querySelector("[data-member-directory-body]");
              const search = portal.querySelector("[data-member-search]");
              const pendingMemberAccessMessage =
                "Private member access is ready in the website, but the access-code list is still being connected by the AOS office.";
              let members = [];

              async function api(path, options = {}) {
                const response = await fetch(path, {
                  credentials: "same-origin",
                  ...options,
                  headers: {
                    "content-type": "application/json",
                    ...(options.headers ?? {})
                  }
                });
                let body;

                try {
                  body = await response.json();
                } catch {
                  body = { error: "The member service did not return JSON." };
                }

                if (!response.ok) {
                  throw new Error(body.error ?? "Request failed.");
                }

                return body;
              }

              function setStatus(node, text, tone = "neutral") {
                if (!node) return;
                node.textContent = text;
                node.dataset.tone = tone;
              }

              function memberErrorText(error) {
                const text = error?.message ?? "The member service is not available right now.";
                return text.includes("not configured") || text.includes("being connected")
                  ? pendingMemberAccessMessage
                  : text;
              }

              function showPrivate(show) {
                loginPanel.hidden = show;
                privatePanel.hidden = !show;
              }

              function addLine(parent, text) {
                if (!text) return;
                const span = document.createElement("span");
                span.textContent = text;
                parent.append(span);
              }

              function addContact(parent, label, value, href) {
                if (!value) return;
                const item = document.createElement(href ? "a" : "span");
                item.textContent = `${label}: ${value}`;
                if (href) item.href = href;
                parent.append(item);
              }

              function renderDirectory(list) {
                tbody.innerHTML = "";

                list.forEach((member) => {
                  const row = document.createElement("tr");
                  const memberCell = document.createElement("th");
                  const practiceCell = document.createElement("td");
                  const contactCell = document.createElement("td");
                  const detailsCell = document.createElement("td");
                  const contactStack = document.createElement("div");
                  const detailStack = document.createElement("div");

                  memberCell.scope = "row";
                  memberCell.textContent = member.name;
                  contactStack.className = "member-directory__stack";
                  detailStack.className = "member-directory__stack";

                  practiceCell.textContent = [member.hospital, member.city].filter(Boolean).join(" · ") || "Not listed";
                  addContact(contactStack, "Mobile", member.mobile, member.mobile ? `tel:${member.mobile.replace(/\\s+/g, "")}` : "");
                  addContact(contactStack, "WhatsApp", member.whatsapp, member.whatsapp ? `tel:${member.whatsapp.replace(/\\s+/g, "")}` : "");
                  addContact(contactStack, "Email", member.email, member.email ? `mailto:${member.email}` : "");
                  addLine(detailStack, member.qualification);
                  addLine(detailStack, member.appointment);
                  addLine(detailStack, member.interest);
                  addLine(detailStack, member.executivePost);

                  if (!contactStack.children.length) addLine(contactStack, "Contact not shared");
                  if (!detailStack.children.length) addLine(detailStack, "Details not listed");

                  contactCell.append(contactStack);
                  detailsCell.append(detailStack);
                  row.append(memberCell, practiceCell, contactCell, detailsCell);
                  tbody.append(row);
                });

                wrap.hidden = list.length === 0;
                setStatus(message, list.length ? "" : "No members match this search.", list.length ? "neutral" : "warning");
              }

              function filterDirectory() {
                const query = (search.value ?? "").trim().toLowerCase();
                const filtered = query
                  ? members.filter((member) =>
                      [
                        member.name,
                        member.city,
                        member.hospital,
                        member.qualification,
                        member.appointment,
                        member.interest,
                        member.executivePost
                      ]
                        .filter(Boolean)
                        .join(" ")
                        .toLowerCase()
                        .includes(query)
                    )
                  : members;

                renderDirectory(filtered);
              }

              async function loadDirectory() {
                showPrivate(true);
                setStatus(message, "Loading member directory…");

                try {
                  const result = await api("/.netlify/functions/member-directory");

                  if (!result.configured) {
                    members = [];
                    countLabel.textContent = "Directory data is ready for secure connection.";
                    wrap.hidden = true;
                    setStatus(
                      message,
                      "Member login is working. The private directory source has not been connected on Netlify yet; members can use the update form meanwhile.",
                      "warning"
                    );
                    return;
                  }

                  members = result.members ?? [];
                  countLabel.textContent = `${result.count ?? members.length} member records available${result.updatedAt ? ` · Updated ${result.updatedAt}` : ""}`;
                  setStatus(message, "");
                  filterDirectory();
                } catch (error) {
                  members = [];
                  wrap.hidden = true;
                  setStatus(message, memberErrorText(error), "danger");
                }
              }

              loginForm.addEventListener("submit", async (event) => {
                event.preventDefault();
                const form = new FormData(loginForm);
                setStatus(loginStatus, "Checking access code…");

                try {
                  await api("/.netlify/functions/member-login", {
                    method: "POST",
                    body: JSON.stringify({ accessCode: form.get("accessCode") })
                  });
                  loginForm.reset();
                  setStatus(loginStatus, "");
                  await loadDirectory();
                } catch (error) {
                  setStatus(loginStatus, memberErrorText(error), "danger");
                }
              });

              logoutButton.addEventListener("click", async () => {
                await api("/.netlify/functions/member-logout", { method: "POST" });
                members = [];
                tbody.innerHTML = "";
                wrap.hidden = true;
                showPrivate(false);
                setStatus(loginStatus, "Logged out.", "success");
              });

              search.addEventListener("input", filterDirectory);

              api("/.netlify/functions/member-session")
                .then((result) => {
                  if (result.authenticated) {
                    loadDirectory();
                  }
                })
                .catch(() => {
                  showPrivate(false);
                });
            })();
          </script>
        )
      }

      {
        page.kind === "public-directory" && (
          <script is:inline>
            (() => {
              const directory = document.querySelector("[data-public-directory]");

              if (!directory) return;

              const search = directory.querySelector("[data-public-directory-search]");
              const count = directory.querySelector("[data-public-directory-count]");
              const message = directory.querySelector("[data-public-directory-message]");
              const wrap = directory.querySelector("[data-public-directory-wrap]");
              const tbody = directory.querySelector("[data-public-directory-body]");
              let surgeons = [];

              function setMessage(text, tone = "neutral") {
                message.textContent = text;
                message.dataset.tone = tone;
              }

              function addLine(parent, text) {
                if (!text) return;
                const span = document.createElement("span");
                span.textContent = text;
                parent.append(span);
              }

              function renderRows(list) {
                tbody.innerHTML = "";

                list.forEach((surgeon) => {
                  const row = document.createElement("tr");
                  const nameCell = document.createElement("th");
                  const practiceCell = document.createElement("td");
                  const detailCell = document.createElement("td");
                  const interestCell = document.createElement("td");
                  const details = document.createElement("div");

                  nameCell.scope = "row";
                  nameCell.textContent = surgeon.name;
                  details.className = "member-directory__stack";

                  practiceCell.textContent = [surgeon.hospital, surgeon.city].filter(Boolean).join(" · ") || "Agra";
                  addLine(details, surgeon.qualification);
                  addLine(details, surgeon.appointment);
                  if (!details.children.length) addLine(details, "Details not listed");
                  detailCell.append(details);
                  interestCell.textContent = surgeon.interest || "Not listed";

                  row.append(nameCell, practiceCell, detailCell, interestCell);
                  tbody.append(row);
                });

                wrap.hidden = list.length === 0;
                setMessage(list.length ? "" : "No surgeon matches this search.", list.length ? "neutral" : "warning");
              }

              function filterRows() {
                const query = (search.value ?? "").trim().toLowerCase();
                const filtered = query
                  ? surgeons.filter((surgeon) =>
                      [
                        surgeon.name,
                        surgeon.city,
                        surgeon.hospital,
                        surgeon.qualification,
                        surgeon.appointment,
                        surgeon.interest
                      ]
                        .filter(Boolean)
                        .join(" ")
                        .toLowerCase()
                        .includes(query)
                    )
                  : surgeons;

                renderRows(filtered);
              }

              async function loadPublicDirectory() {
                try {
                  const response = await fetch("/.netlify/functions/public-directory", {
                    credentials: "same-origin"
                  });
                  const result = await response.json();

                  if (!response.ok) {
                    throw new Error(result.error ?? "Public directory is not available right now.");
                  }

                  if (!result.configured) {
                    surgeons = [];
                    count.textContent = "Directory source is being connected.";
                    wrap.hidden = true;
                    setMessage("The public directory source is being connected by the AOS office.", "warning");
                    return;
                  }

                  surgeons = result.members ?? [];
                  count.textContent = `${result.count ?? surgeons.length} Agra surgeon listings${result.updatedAt ? ` · Updated ${result.updatedAt}` : ""}`;
                  filterRows();
                } catch (error) {
                  surgeons = [];
                  count.textContent = "Directory unavailable";
                  wrap.hidden = true;
                  setMessage(error?.message ?? "Public directory is not available right now.", "danger");
                }
              }

              search.addEventListener("input", filterRows);
              loadPublicDirectory();
            })();
          </script>
        )
      }

      {
        page.kind === "downloads" && !showComingSoon && (
          <section aria-labelledby="downloads-heading">
            <div class="content-heading">
              <h2 id="downloads-heading">Available files</h2>
              <p>Only source files found in the existing AOS archive are shown.</p>
            </div>
            <div class="download-list">
              <a href="/assets/documents/orthocon-2025.pdf" download>
                <span class="download-list__icon"><Icon name="file" size={22} /></span>
                <span><strong>ORTHOCON event brochure</strong><small>PDF · Archived event material</small></span>
                <Icon name="download" size={20} />
              </a>
            </div>
          </section>
        )
      }

      {
        page.kind === "conference-archive" && (
          <section aria-labelledby="conference-material-heading">
            <div class="content-heading">
              <h2 id="conference-material-heading">Original conference material</h2>
              <p>The brochure below is the original PDF linked from the previous website.</p>
            </div>
            <div class="download-list">
              <a href="/assets/documents/orthocon-2025.pdf" download>
                <span class="download-list__icon"><Icon name="file" size={22} /></span>
                <span><strong>50th UP Golden Jubilee ORTHOCON brochure</strong><small>PDF · February 2026 conference</small></span>
                <Icon name="download" size={20} />
              </a>
            </div>
          </section>
        )
      }

      {
        page.kind === "notices" && (
          <section aria-labelledby="notices-heading">
            <div class="content-heading">
              <h2 id="notices-heading">Current notices</h2>
              <p>Dates are ordered by the event date.</p>
            </div>
            <div class="notice-list notice-list--interior">
              {notices.map((notice) => (
                <a href={notice.href}>
                  <time datetime={notice.datetime}>{notice.dateLabel}</time>
                  <span><strong>{notice.title}</strong><small>{notice.summary}</small></span>
                  <Icon name="arrow-right" size={18} />
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        page.kind === "videos" && (
          <section class="video-gallery" aria-labelledby="video-gallery-heading">
            <div class="content-heading">
              <h2 id="video-gallery-heading">Recorded AOS programmes</h2>
              <p>
                These recordings are embedded from the society YouTube channel and open there for full-screen viewing or sharing.
              </p>
            </div>
            <div class="video-gallery__grid">
              {videoRecordings.map((video) => (
                <article class="video-card">
                  <div class="video-card__frame">
                    <iframe
                      src={`https://www.youtube.com/embed/${video.id}`}
                      title={video.title}
                      loading="lazy"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                    />
                  </div>
                  <div class="video-card__body">
                    <p>{video.event} · {video.date}</p>
                    <h3>{video.title}</h3>
                    <small>{video.summary}</small>
                    <a class="text-link" href={video.url} target="_blank" rel="noreferrer">
                      Watch on YouTube <Icon name="external" size={16} />
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        page.sections?.map((section) => (
          <section class="prose-section">
            <h2>{section.title}</h2>
            {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets && (
              <ul>
                {section.bullets.map((bullet) => {
                  const rawUrl = bullet.match(/(?:https?:\/\/\S+|\/[^\s]+\/?)$/)?.[0];
                  const label = rawUrl ? bullet.replace(` — ${rawUrl}`, "") : bullet;
                  const attrs = rawUrl?.startsWith("http") ? { target: "_blank", rel: "noreferrer" } : {};
                  return (
                    <li>
                      <Icon name="check" size={17} />
                      {rawUrl ? <a href={rawUrl} {...attrs}>{label} <Icon name={rawUrl.startsWith("http") ? "external" : "arrow-right"} size={15} /></a> : label}
                    </li>
                  );
                })}
              </ul>
            )}
          </section>
        ))
      }

      {
        page.slug === "public-awareness" && (
          <section class="awareness-index" aria-labelledby="awareness-index-heading">
            <div class="content-heading">
              <h2 id="awareness-index-heading">Public-awareness topic pages</h2>
              <p>
                These pages can support daily Facebook posts and give visitors a clear place to read the main points again.
              </p>
            </div>
            <div class="awareness-index__links">
              {publicAwarenessTopics.map((topic) => (
                <a href={topic.href}>
                  <span>
                    <small>{topic.label}</small>
                    <strong>{topic.title}</strong>
                    <em>{topic.copy}</em>
                  </span>
                  <Icon name="arrow-right" size={18} />
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        page.slug === "aos-legacy" && (
          <section class="archive-index" aria-labelledby="archive-index-heading">
            <div class="content-heading">
              <h2 id="archive-index-heading">Explore the society archive</h2>
              <p>Verified records and clearly dated legacy material, kept separate from current society information.</p>
            </div>
            <div class="archive-index__links">
              <a href="/past-leadership/"><span><strong>Past Presidents & Secretaries</strong><small>Leadership register</small></span><Icon name="arrow-right" size={18} /></a>
              <a href="/executive-body/"><span><strong>Executive Body 2025–2026</strong><small>Previous-term roster</small></span><Icon name="arrow-right" size={18} /></a>
              <a href="/president-message-2025-2026/"><span><strong>President’s Message 2025–2026</strong><small>Archived message</small></span><Icon name="arrow-right" size={18} /></a>
              <a href="/ioacon-2013-archive/"><span><strong>IOACON 2013</strong><small>Conference archive</small></span><Icon name="arrow-right" size={18} /></a>
            </div>
          </section>
        )
      }

      {
        page.slug === "president-message" && (
          <section class="archive-reference">
            <div>
              <p>Looking for the previous term?</p>
              <h2>President’s Message 2025–2026</h2>
            </div>
            <a class="text-link" href="/president-message-2025-2026/">Read the archived message <Icon name="arrow-right" size={17} /></a>
          </section>
        )
      }

      {
        page.slug === "executive-committee" && (
          <section class="archive-reference">
            <div>
              <p>Previous-term record</p>
              <h2>Executive Body 2025–2026</h2>
            </div>
            <a class="text-link" href="/executive-body/">View the archived roster <Icon name="arrow-right" size={17} /></a>
          </section>
        )
      }
    </article>

    <aside class="interior__aside" aria-label="Related pages">
      <div class="aside-panel">
        <p>In this section</p>
        <a class:list={[{ active: canonicalPath === groupNavigation?.href }]} href={groupNavigation?.href ?? "/"}>
          {groupNavigation?.label ?? page.group} overview
        </a>
        {groupNavigation?.items
          .filter((item) => item.href !== groupNavigation.href && item.href !== "/contact/")
          .map((item) => (
          <a class:list={[{ active: canonicalPath === item.href }]} href={item.href} {...linkAttrs(item.href)}>{item.label}</a>
          ))}
      </div>
      <div class="aside-contact">
        <h2>Need help?</h2>
        <p>Contact the AOS team for society, membership, or programme enquiries.</p>
        <a class="text-link" href="/contact/">Contact AOS <Icon name="arrow-right" size={17} /></a>
      </div>
    </aside>
  </div>
</BaseLayout>
